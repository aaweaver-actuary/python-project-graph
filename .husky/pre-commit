#!/usr/bin/env sh
set -eu

branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo unknown)"

# Allow the first bootstrap commit on main, block subsequent commits.
if [ "$branch" = "main" ] && git rev-parse --verify HEAD >/dev/null 2>&1; then
  echo "Direct commits to main are blocked. Create and switch to a feature branch."
  exit 1
fi

staged_file_count="$(git diff --cached --name-only --diff-filter=ACMR | wc -l | tr -d ' ')"
staged_line_count="$(git diff --cached --numstat --diff-filter=ACMR | awk '$1 ~ /^[0-9]+$/ && $2 ~ /^[0-9]+$/ { add += $1; del += $2 } END { print add + del + 0 }')"

max_files=20
max_lines=600

if [ "$staged_file_count" -gt "$max_files" ] || [ "$staged_line_count" -gt "$max_lines" ]; then
  echo "Commit is too large for a single changeset."
  echo "Staged files: $staged_file_count (max $max_files)"
  echo "Staged changed lines: $staged_line_count (max $max_lines)"
  echo "Split the work into smaller commits."
  exit 1
fi

npx --no -- lint-staged
